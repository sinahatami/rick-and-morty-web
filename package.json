{
  "homepage": "https://sinahatami.github.io/rick-and-morty-web",
  "name": "rick-and-morty-web",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:e2e": "BUILD_FOR_E2E=true next build",
    "start": "npx serve@latest out -p 3000",
    "lint": "eslint . --max-warnings 0 --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "test": "jest --watch",
    "test:ci": "jest --ci",
    "test:once": "jest",
    "test:preview": "jest-preview",
    "test:e2e": "start-server-and-test dev http://localhost:3000 'cypress run'",
    "test:e2e:ci": "start-server-and-test start http://localhost:3000 'cypress run'",
    "test:e2e:full": "yarn build:e2e && yarn test:e2e:ci",
    "verify": "yarn lint && yarn test:once && yarn test:e2e:full",
    "cypress:open": "start-server-and-test dev http://localhost:3000 'cypress open'",
    "analyze": "ANALYZE=true next build",
    "deploy": "yarn build && yarn run gh-pages -d out -t",
    "knip": "knip",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.90.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.562.0",
    "next": "^15.5.9",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@next/bundle-analyzer": "^16.1.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "cypress": "^15.18.1",
    "eslint": "8.57.0",
    "eslint-config-next": "15.1.6",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preview": "^0.3.3",
    "knip": "^5.80.2",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "sass": "^1.101.0",
    "semantic-release": "^25.0.5",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4.1.18",
    "typescript": "5.3.3"
  },
  "packageManager": "yarn@4.9.2",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,scss,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  }
}
